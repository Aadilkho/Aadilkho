{
  "expo": {
    "name": "CarIQ",
    "slug": "cariq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cariq.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.cariq.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "cariq",
    "updates": {
      "enabled": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6855b262-3124-4bf3-a02c-b2f33095768c"
      }
    },
    "owner": "aadilkho"
  }
}
